# Example environment configuration
# Copy this file to .env (for Prisma CLI) and .env.local (for app runtime) and fill in values.
# Never commit real secrets.

# Database connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/globiz_patholab?schema=public"

# Public API URL used by the frontend
NEXT_PUBLIC_API_URL="http://localhost:3005"

# Email credentials (use app password if using Gmail)
GMAIL_USER="your_gmail_username@example.com"
GMAIL_APP_PASSWORD="your_app_password_here"
